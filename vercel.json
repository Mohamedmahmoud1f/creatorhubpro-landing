{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(api|account-analysis)(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!static/|brand/|favicon.ico).*)",
      "destination": "/api/index.ts"
    }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}